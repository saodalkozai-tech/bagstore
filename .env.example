# BagStore Environment Variables
# Copy this to .env.local and fill in your actual values
# Never commit .env.local to git!

# ========================================
# SUPABASE (Cloud Sync - Recommended)
# ========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_SUPABASE_DB_NAME=your-db-name
# You can leave cloud sync disabled from the admin settings screen until these values are ready.

# ========================================
# CLOUDINARY (Image Uploads)
# ========================================
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
VITE_CLOUDINARY_API_KEY=your-api-key
# Optional for the current unsigned upload flow; kept for docs/admin display only.

# ========================================
# FIREBASE (Optional Auth)
# ========================================
VITE_USE_FIREBASE_AUTH=true  # Set false to disable
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
# For role assignment script (server-side only, do NOT expose in client):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_PROJECT_ID=your-project-id

# ========================================
# Store Defaults (Override as needed)
# ========================================
VITE_STORE_PHONE=+964xxxxxxxxx
VITE_STORE_EMAIL=info@yourstore.com

# Add to .gitignore:
# .env.local
# .env.*.local

# Production notes:
# - Use Firebase Auth for admin users in production.
# - Do not keep demo/local passwords enabled in production.
# - Store all real secrets in hosting platform secret manager only.
